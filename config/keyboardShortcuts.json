{
  "shortcuts": [
    {
      "key": "Tab",
      "action": "toggleControls",
      "description": "Toggle controls panel",
      "preventDefault": true
    },
    {
      "key": "Enter",
      "action": "toggleFullscreen",
      "description": "Toggle fullscreen",
      "preventDefault": true
    },
    {
      "key": "P",
      "action": "exportPNG",
      "description": "Export PNG",
      "preventDefault": true
    },
    {
      "key": "S",
      "action": "exportSVG",
      "description": "Export SVG",
      "preventDefault": true
    },
    {
      "key": "D",
      "action": "exportDepthMap",
      "description": "Export depth map",
      "preventDefault": true
    },
    {
      "key": "s",
      "action": "downloadJSON",
      "description": "Save settings JSON (Cmd/Ctrl+S)",
      "preventDefault": true,
      "ctrl": true
    },
    {
      "key": "R",
      "action": "resetCamera",
      "description": "Reset camera",
      "preventDefault": true
    },
    {
      "key": "0",
      "action": "resetZoom",
      "description": "Reset zoom to default",
      "preventDefault": true
    },
    {
      "key": "t",
      "action": "toggleRandomThickness",
      "description": "Toggle random thickness",
      "preventDefault": true
    },
    {
      "key": "m",
      "action": "toggleRandomSpeed",
      "description": "Toggle random speed",
      "preventDefault": true
    },
    {
      "key": "1",
      "action": "selectPalette1",
      "description": "Select Color Palette 1",
      "preventDefault": true
    },
    {
      "key": "2",
      "action": "selectPalette2",
      "description": "Select Color Palette 2",
      "preventDefault": true
    },
    {
      "key": "3",
      "action": "selectPalette3",
      "description": "Select Color Palette 3",
      "preventDefault": true
    },
    {
      "key": "4",
      "action": "selectPalette4",
      "description": "Select Color Palette 4",
      "preventDefault": true
    },
    {
      "key": "y",
      "action": "toggleStereoMode",
      "description": "Toggle stereoscopic view",
      "preventDefault": true
    }
  ]
}
