{
  "shortcuts": [
    {
      "key": "Tab",
      "action": "toggleControls",
      "description": "Toggle controls panel",
      "preventDefault": true
    },
    {
      "key": "Enter",
      "action": "toggleFullscreen",
      "description": "Toggle fullscreen",
      "preventDefault": true
    },
    {
      "key": "P",
      "action": "exportPNG",
      "description": "Export PNG",
      "preventDefault": true
    },
    {
      "key": "S",
      "action": "exportSVG",
      "description": "Export SVG",
      "preventDefault": true
    },
    {
      "key": "D",
      "action": "exportDepthMap",
      "description": "Export depth map",
      "preventDefault": true
    },
    {
      "key": "s",
      "action": "downloadJSON",
      "description": "Settings Saved as JSON",
      "preventDefault": true,
      "ctrl": true
    },
    {
      "key": "R",
      "action": "resetCamera",
      "description": "Reset Camera",
      "preventDefault": true
    },
    {
      "key": "0",
      "action": "resetCamera",
      "description": "Reset Zoom & Orbit",
      "preventDefault": true
    },
    {
      "key": "t",
      "action": "toggleRandomThickness",
      "description": "Random thickness",
      "preventDefault": true
    },
    {
      "key": "m",
      "action": "toggleRandomSpeed",
      "description": "Random speed",
      "preventDefault": true
    },
    {
      "key": "1",
      "action": "selectPalette1",
      "description": "Color Palette 1",
      "preventDefault": true
    },
    {
      "key": "2",
      "action": "selectPalette2",
      "description": "Color Palette 2",
      "preventDefault": true
    },
    {
      "key": "3",
      "action": "selectPalette3",
      "description": "Color Palette 3",
      "preventDefault": true
    },
    {
      "key": "4",
      "action": "selectPalette4",
      "description": "Color Palette 4",
      "preventDefault": true
    },
    {
      "key": "c",
      "action": "copyPalette",
      "description": "Copy Palette",
      "preventDefault": true,
      "ctrl": true
    },
    {
      "key": "v",
      "action": "pastePalette",
      "description": "Paste Palette",
      "preventDefault": true,
      "ctrl": true
    },
    {
      "key": "y",
      "action": "toggleStereoMode",
      "description": "Stereoscopic view",
      "preventDefault": true
    },
    {
      "key": " ",
      "action": "autoTriggerPlayPause",
      "description": "States Player",
      "preventDefault": true
    },
    {
      "key": "ArrowRight",
      "action": "autoTriggerSkip",
      "description": "Next state",
      "preventDefault": true
    },
    {
      "key": "ArrowLeft",
      "action": "autoTriggerPrevious",
      "description": "Previous state",
      "preventDefault": true
    },
    {
      "key": "i",
      "action": "toggleShortcutsToast",
      "description": "Shortcuts info",
      "preventDefault": true
    }
  ]
}
